# App
APP_NAME=Enterprise Workflow API
ENVIRONMENT=local
API_PREFIX=/api
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+psycopg2://workflow:workflow@localhost:5432/workflow

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# File uploads
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.gif,.txt,.md,.csv

# Email (Celery tasks log if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@example.com

# Rate limits (per minute, per IP)
RATE_LIMIT_PER_MINUTE=120

# Optional: public base URL (docs, webhooks; keep empty if not used)
PUBLIC_BASE_URL=

# S3: leave S3_BUCKET empty to store uploads on local disk (UPLOAD_DIR).
# On AWS EC2 with an instance role, omit AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY.
S3_BUCKET=
S3_PREFIX=attachments
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3-compatible (MinIO, DigitalOcean Spaces, etc.):
S3_ENDPOINT_URL=
